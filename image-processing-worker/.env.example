# Worker identity
WORKER_ID=processing-1

# Logging
LOG_LEVEL=INFO

# Redis (job queue)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# image-api connection
API_BASE_URL=http://image-api:3001
API_JWT=system-service-jwt-token

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=image-service
MINIO_USE_SSL=false

# SMB mount (local path where SMB shares are mounted)
SMB_MOUNT_PATH=/mnt/smb

# Processing
PROCESSING_CONCURRENCY=4
PNG_COMPRESSION_LEVEL=6
THUMBNAIL_SIZE=512
TIFF_RESOLUTION_DPI=300

# Retry
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Health
HEALTH_PORT=9200
