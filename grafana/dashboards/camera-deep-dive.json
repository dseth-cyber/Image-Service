    {
      "id": 20, "title": "Camera Status (per camera)", "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "image_service_camera_status", "legendFormat": "", "refId": "A", "instant": true, "format": "table" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "camera_name" }, "properties": [{ "id": "displayName", "value": "Camera" }, { "id": "custom.width", "value": 250 }] },
          { "matcher": { "id": "byName", "options": "status" }, "properties": [{ "id": "displayName", "value": "Status" }, { "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Code" }, { "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "__name__" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "camera_id" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "instance" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "job" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "transformations": [{ "id": "sortBy", "options": { "sort": [{ "field": "status", "desc": false }] } }],
      "options": { "showHeader": true, "footer": { "show": true, "reducer": ["count"], "countRows": true } }
    },
    {
      "id": 21, "title": "Images per Camera", "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "image_service_camera_images_total", "legendFormat": "{{camera_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color":"cyan","value":null}] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 22, "title": "Last Poll (seconds ago)", "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "image_service_camera_last_poll_seconds", "legendFormat": "{{camera_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":120},{"color":"red","value":300}] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "image-service",
    "cameras"
  ],
