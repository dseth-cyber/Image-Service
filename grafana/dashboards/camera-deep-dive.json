    },
    {
      "id": 4,
      "title": "Queue \u2014 Wait vs Active",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "image_service_queue_depth{state=\"wait\"}",
          "legendFormat": "Wait",
          "refId": "A"
        },
        {
          "expr": "image_service_queue_depth{state=\"active\"}",
          "legendFormat": "Active",
          "refId": "B"
        },
        {
          "expr": "image_service_queue_depth{state=\"failed\"}",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "showPoints": "always",
            "pointSize": 5,
            "lineWidth": 2
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
