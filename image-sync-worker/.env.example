# Environment
NODE_ENV=development
LOG_LEVEL=info

# image-api connection
API_BASE_URL=http://image-api:3001
API_JWT=system-service-jwt-token

# Redis (for BullMQ job queue + tracking)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Polling
POLL_INTERVAL_MS=30000
POLL_CONCURRENCY=5

# Checksum
CHECKSUM_ALGORITHM=md5

# Tracker (dedup via Redis)
PROCESSED_TTL_DAYS=7

# Retry
RETRY_MAX_RETRIES=3
RETRY_INITIAL_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# Health server
HEALTH_PORT=9100
