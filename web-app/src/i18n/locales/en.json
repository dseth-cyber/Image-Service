      },
      "rulesGroups": {
        "priority1": [
          "Shared Layout — every page wraps <Layout>",
          "Central Dialog — uses <Modal> / <ConfirmDialog>, never alert()",
          "5-Language i18n — all UI text via t('key') (th/en/cn/mm/jp)",
          "Theme tokens — all theme-dependent styling from themeConfig",
          "SearchableSelect — no native <select> allowed",
          "React Query — useQuery + invalidateQueries, no useEffect+setState",
          "Date Display — formatDate(date, i18n.language) always",
          "Table UX — TableSkeleton, sortable columns, ColumnSelector, pagination"
        ],
        "priority2": [
          "authorize() on write — every POST/PUT/PATCH/DELETE",
          "Soft Delete — deletedAt + trash/restore, never hard delete"
        ],
        "priority3": [
          "Low-Code Config — business rules via Admin UI, never hardcoded"
        ],
        "priority4": [
          "Masterdata Fields — code @unique, name 5 languages, description, sortOrder, isActive"
        ],
        "priority5": [
          "Kafka Event Standard — image.processed event for ERP services"
        ],
        "imageService": [
          "Image Storage Rule — every image has raw + processed + thumbnail in image_files",
          "Traceability Rule — every image traces to Camera → Machine → Lot → Operator → Shift",
          "Event Rule — emit event on processing complete for downstream services"
        ]
      },
      "archStack": [
        {
          "label": "Capture Devices",
          "tech": "SMB Share · TIFF",
          "desc": "Windows PCs capture TIFF images via SMB network share. Initial: 1 camera, Scale: 30+ cameras, millions of images/day."
        },
        {
          "label": "Sync Worker",
          "tech": "Node.js 22 · TypeScript",
          "desc": "Scans SMB folders, detects new TIFFs, computes checksum, prevents duplicates, creates processing jobs."
        },
        {
          "label": "Processing Worker",
          "tech": "Python 3.12 · Pillow",
          "desc": "Converts TIFF→PNG, generates thumbnails, calculates SHA256 checksum, stores in MinIO, reports result to API which writes metadata to DB."
        },
        {
