        "priority1": [
          "Shared Layout — 每个页面包裹 <Layout>",
          "Central Dialog — 使用 <Modal>/<ConfirmDialog>，禁止 alert()",
          "5-Language i18n — 所有UI文本用 t('key') (th/en/cn/mm/jp)",
          "Theme tokens — 主题样式来自 themeConfig",
          "SearchableSelect — 禁止原生 <select>",
          "React Query — useQuery + invalidateQueries，禁止 useEffect+setState",
          "Date Display — 始终用 formatDate(date, i18n.language)",
          "Table UX — TableSkeleton, 排序列, ColumnSelector, 分页"
        ],
        "priority2": [
          "authorize() on write — 每个 POST/PUT/PATCH/DELETE",
          "Soft Delete — deletedAt + trash/restore，不硬删除"
        ],
        "priority3": [
          "Low-Code Config — 业务规则通过Admin UI设置，不硬编码"
        ],
        "priority4": [
          "Masterdata Fields — code @unique, name 5种语言, description, sortOrder, isActive"
        ],
        "priority5": [
          "Kafka Event Standard — image.processed 事件供ERP服务"
        ],
        "imageService": [
          "Image Storage Rule — 每张图在 image_files 中有 raw + processed + thumbnail",
          "Traceability Rule — 每张图追溯到 Camera → Machine → Lot → Operator → Shift",
          "Event Rule — 处理完成后发出事件供下游服务"
        ]
