# === Global ===
COMPOSE_PROJECT_NAME=image-service

# === PostgreSQL ===
POSTGRES_USER=image_user
POSTGRES_PASSWORD=image_pass
POSTGRES_DB=image_db

# === JWT ===
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === MinIO ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=image-service

# === Encryption (SMB passwords) ===
ENCRYPTION_KEY=dev-encryption-key-32chars!!

# === Service API Key (internal service-to-service auth) ===
SERVICE_API_KEY=dev-service-api-key-change-in-production

# === SMB Server ===
SMB_USER=camera
SMB_PASSWORD=smbpass
