generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  operator
  viewer
  system

  @@map("role")
}

enum ImageStatus {
  pending
  queued
  processing
  completed
  failed
  deleted
  archived

  @@map("image_status")
}

enum FileType {
  raw
  processed
  thumbnail
  metadata_json

  @@map("file_type")
}

enum StorageClass {
  hot
  warm
  cold

  @@map("storage_class")
}

enum CameraStatus {
  active
  inactive
  error
  maintenance

  @@map("camera_status")
}

enum CameraEventType {
  online
  offline
  error
  reconfigured
  maintenance_start
  maintenance_end
  image_deleted

  @@map("camera_event_type")
}

enum AlertSeverity {
  info
  warning
  critical
  emergency

  @@map("alert_severity")
}

enum AlertType {
  storage_warning
  processing_failure
  camera_offline
  rate_limit_exceeded
  retention_violation
  disk_space
  ingest_lag
  checksum_mismatch

  @@map("alert_type")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  username  String    @unique @db.VarChar(128)
  email     String    @unique @db.VarChar(256)
  password  String    @db.Text
  role      Role      @default(viewer)
  enabled   Boolean   @default(true)
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.Text
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model RetentionPolicy {
  id                     String       @id @default(uuid()) @db.Uuid
  name                   String       @db.VarChar(128)
  description            String?      @db.Text
  rawRetentionDays       Int          @map("raw_retention_days")
  processedRetentionDays Int          @map("processed_retention_days")
  thumbnailRetentionDays Int          @map("thumbnail_retention_days")
  archiveRawDays         Int?         @map("archive_raw_days")
  archiveEnabled         Boolean      @default(false) @map("archive_enabled")
  coldStorageClass       StorageClass @default(cold) @map("cold_storage_class")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  cameras Camera[]

  @@map("retention_policies")
}

model Camera {
  id                     String       @id @default(uuid()) @db.Uuid
  name                   String       @db.VarChar(128)
  description            String?      @db.Text
  ipAddress              String       @map("ip_address") @db.VarChar(45)
  smbSharePath           String       @map("smb_share_path") @db.Text
  smbDomain              String?      @db.VarChar(128)
  smbUsername            String       @map("smb_username") @db.VarChar(256)
  smbPasswordEncrypted   String       @map("smb_password_encrypted") @db.Text
  smbSubdirectoryPattern String?      @map("smb_subdirectory_pattern") @db.VarChar(256)
  status                 CameraStatus @default(inactive)
  pollIntervalSeconds    Int          @default(30) @map("poll_interval_seconds")
  timezone               String?      @default("UTC") @db.VarChar(64)
  metadata               Json         @default("{}")
  captureMode            String       @default("periodic") @map("capture_mode") @db.VarChar(32)
  retentionPolicyId      String       @map("retention_policy_id") @db.Uuid
  enabled                Boolean      @default(true)
  lastPolledAt           DateTime?    @map("last_polled_at")
  lastImageAt            DateTime?    @map("last_image_at")
  totalImagesCount       BigInt       @default(0) @map("total_images_count")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  retentionPolicy  RetentionPolicy   @relation(fields: [retentionPolicyId], references: [id])
  images           Image[]
  cameraEvents     CameraEvent[]
  storageSnapshots StorageSnapshot[]

  @@map("cameras")
}

model Image {
  id               String      @id @default(uuid()) @db.Uuid
  cameraId         String      @map("camera_id") @db.Uuid
  originalFilename String      @map("original_filename") @db.VarChar(512)
  fileSizeBytes    BigInt      @map("file_size_bytes")
  checksumSha256   String?     @map("checksum_sha256") @db.Char(64)
  checksumMd5      String?     @map("checksum_md5") @db.Char(32)
  status           ImageStatus @default(pending)
  widthPx          Int?        @map("width_px")
  heightPx         Int?        @map("height_px")
  bitDepth         Int?        @map("bit_depth")
  colorSpace       String?     @map("color_space") @db.VarChar(32)
  compressionType  String?     @map("compression_type") @db.VarChar(64)
  compressionRatio Decimal?    @map("compression_ratio") @db.Decimal(5, 2)
  tiffMetadata     Json?       @default("{}") @map("tiff_metadata")
  capturedAt       DateTime    @map("captured_at")
  ingestedAt       DateTime    @default(now()) @map("ingested_at")
  processedAt      DateTime?   @map("processed_at")
  deletedAt        DateTime?   @map("deleted_at")
  retentionUntil   DateTime?   @map("retention_until")
  createdAt        DateTime    @default(now()) @map("created_at")

  camera         Camera          @relation(fields: [cameraId], references: [id])
  imageFiles     ImageFile[]
  imageTags      ImageTag[]
  processingJobs ProcessingJob[]

  @@index([cameraId, capturedAt(sort: Desc)])
  @@index([status])
  @@index([checksumMd5])
  @@index([retentionUntil])
  @@map("images")
}

model ImageFile {
  id             String       @id @default(uuid()) @db.Uuid
  imageId        String       @map("image_id") @db.Uuid
  fileType       FileType     @map("file_type")
  bucket         String       @db.VarChar(128)
  objectKey      String       @db.Text
  storageClass   StorageClass @default(hot) @map("storage_class")
  fileSizeBytes  BigInt       @map("file_size_bytes")
  checksumSha256 String?      @map("checksum_sha256") @db.Char(64)
  mimeType       String?      @map("mime_type") @db.VarChar(128)
  createdAt      DateTime     @default(now()) @map("created_at")

  image Image @relation(fields: [imageId], references: [id])

  @@unique([imageId, fileType])
  @@map("image_files")
}

model ImageTag {
  id        BigInt   @id @default(autoincrement())
  imageId   String   @map("image_id") @db.Uuid
  key       String   @db.VarChar(128)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  image Image @relation(fields: [imageId], references: [id])

  @@unique([imageId, key])
  @@index([key, value])
  @@map("image_tags")
}

model ProcessingJob {
  id           String    @id @default(uuid()) @db.Uuid
  imageId      String?   @map("image_id") @db.Uuid
  jobType      String    @map("job_type") @db.VarChar(32)
  workerId     String?   @map("worker_id") @db.VarChar(128)
  status       String    @default("queued") @db.VarChar(32)
  priority     Int       @default(0)
  queueName    String    @default("default") @map("queue_name") @db.VarChar(64)
  payload      Json?
  result       Json?
  errorMessage String?   @map("error_message") @db.Text
  errorDetails Json?     @map("error_details")
  retryCount   Int       @default(0) @map("retry_count")
  maxRetries   Int       @default(3) @map("max_retries")
  queuedAt     DateTime  @default(now()) @map("queued_at")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  image Image? @relation(fields: [imageId], references: [id])

  @@index([imageId])
  @@index([status, queuedAt])
  @@map("processing_jobs")
}

model CameraEvent {
  id        BigInt          @id @default(autoincrement())
  cameraId  String          @map("camera_id") @db.Uuid
  eventType CameraEventType @map("event_type")
  message   String          @db.Text
  metadata  Json?           @default("{}")
  createdAt DateTime        @default(now()) @map("created_at")

  camera Camera @relation(fields: [cameraId], references: [id])

  @@index([cameraId, createdAt(sort: Desc)])
  @@map("camera_events")
}

model StorageSnapshot {
  id           BigInt       @id @default(autoincrement())
  cameraId     String?      @map("camera_id") @db.Uuid
  snapshotDate DateTime     @map("snapshot_date") @db.Date
  fileType     FileType     @map("file_type")
  storageClass StorageClass @default(hot) @map("storage_class")
  totalFiles   BigInt       @default(0) @map("total_files")
  totalBytes   BigInt       @default(0) @map("total_bytes")
  createdAt    DateTime     @default(now()) @map("created_at")

  camera Camera? @relation(fields: [cameraId], references: [id])

  @@unique([cameraId, snapshotDate, fileType, storageClass])
  @@map("storage_snapshots")
}

model Alert {
  id             String        @id @default(uuid()) @db.Uuid
  alertType      AlertType     @map("alert_type")
  severity       AlertSeverity @default(warning)
  source         String?       @db.VarChar(256)
  title          String        @db.VarChar(256)
  message        String        @db.Text
  details        Json?         @default("{}")
  acknowledgedAt DateTime?     @map("acknowledged_at")
  acknowledgedBy String?       @map("acknowledged_by") @db.VarChar(128)
  resolvedAt     DateTime?     @map("resolved_at")
  resolvedBy     String?       @map("resolved_by") @db.VarChar(128)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([severity, createdAt(sort: Desc)])
  @@map("alerts")
}

model AlertRule {
  id                   String    @id @default(uuid()) @db.Uuid
  name                 String    @db.VarChar(128)
  alertType            AlertType @map("alert_type")
  description          String?   @db.Text
  enabled              Boolean   @default(true)
  condition            Json
  cooldownMinutes      Int       @default(60) @map("cooldown_minutes")
  notificationChannels Json      @default("[]") @map("notification_channels")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("alert_rules")
}
