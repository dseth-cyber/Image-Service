# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://image_user:image_pass@localhost:5432/image_db

# JWT
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=image-service
MINIO_USE_SSL=false

# Encryption (for SMB passwords in DB)
ENCRYPTION_KEY=change-this-to-a-32-char-encryption-key

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LINE_ACCESS_TOKEN=
